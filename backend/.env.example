# 数据库配置
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=system_admin

# JWT 配置
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 应用配置
PORT=3000
NODE_ENV=development

# 前端地址 (用于 CORS)
FRONTEND_URL=http://localhost:5173

# 邮件配置（可选）
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your-email@example.com
# MAIL_PASS=your-email-password
# MAIL_FROM=noreply@example.com

# ==========================================
# AI 模型配置
# ==========================================

# 默认 AI 提供商 (deepseek, openai, qwen, moonshot)
AI_DEFAULT_PROVIDER=deepseek

# DeepSeek 配置
AI_DEEPSEEK_API_KEY=your-deepseek-api-key
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_DEEPSEEK_DEFAULT_MODEL=deepseek-chat
AI_DEEPSEEK_CHAT_MODEL=deepseek-chat
AI_DEEPSEEK_ENABLED=true

# OpenAI 配置
AI_OPENAI_API_KEY=your-openai-api-key
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_DEFAULT_MODEL=gpt-3.5-turbo
AI_OPENAI_CHAT_MODEL=gpt-3.5-turbo
AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_OPENAI_ENABLED=false

# 通义千问 (Qwen) 配置
AI_QWEN_API_KEY=your-qwen-api-key
AI_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_QWEN_DEFAULT_MODEL=qwen-turbo
AI_QWEN_CHAT_MODEL=qwen-turbo
AI_QWEN_EMBEDDING_MODEL=text-embedding-v3
AI_QWEN_ENABLED=false

# Moonshot (Kimi) 配置
AI_MOONSHOT_API_KEY=your-moonshot-api-key
AI_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
AI_MOONSHOT_DEFAULT_MODEL=moonshot-v1-8k
AI_MOONSHOT_CHAT_MODEL=moonshot-v1-8k
AI_MOONSHOT_ENABLED=false
