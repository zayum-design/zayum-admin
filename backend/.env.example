# 数据库配置
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=system_admin

# JWT 配置
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 应用配置
PORT=3000
NODE_ENV=development

# 前端地址 (用于 CORS)
FRONTEND_URL=http://localhost:5173

# 邮件配置（可选）
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your-email@example.com
# MAIL_PASS=your-email-password
# MAIL_FROM=noreply@example.com

# ==========================================
# AI 模型配置
# ==========================================

# 默认 AI 提供商 (deepseek, openai, anthropic, qwen, moonshot, openrouter, minimax, zhipu)
AI_DEFAULT_PROVIDER=deepseek

# DeepSeek 配置
AI_DEEPSEEK_API_KEY=your-deepseek-api-key
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_DEEPSEEK_DEFAULT_MODEL=deepseek-chat
AI_DEEPSEEK_CHAT_MODEL=deepseek-chat
AI_DEEPSEEK_ENABLED=true

# OpenAI 配置
AI_OPENAI_API_KEY=your-openai-api-key
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_DEFAULT_MODEL=gpt-3.5-turbo
AI_OPENAI_CHAT_MODEL=gpt-3.5-turbo
AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_OPENAI_ENABLED=false

# 通义千问 (Qwen) 配置
AI_QWEN_API_KEY=your-qwen-api-key
AI_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_QWEN_DEFAULT_MODEL=qwen-turbo
AI_QWEN_CHAT_MODEL=qwen-turbo
AI_QWEN_EMBEDDING_MODEL=text-embedding-v3
AI_QWEN_ENABLED=false

# Moonshot (Kimi) 配置
AI_MOONSHOT_API_KEY=your-moonshot-api-key
AI_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
AI_MOONSHOT_DEFAULT_MODEL=moonshot-v1-8k
AI_MOONSHOT_CHAT_MODEL=moonshot-v1-8k
AI_MOONSHOT_ENABLED=false

# Anthropic Claude 配置
# Claude 是 Anthropic 的 AI 助手，在编程和推理方面表现出色
# 获取 API Key: https://console.anthropic.com/
AI_ANTHROPIC_API_KEY=your-anthropic-api-key
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
AI_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
AI_ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
AI_ANTHROPIC_ENABLED=false

# OpenRouter 配置
# OpenRouter 是一个统一的 AI API 网关，支持 Claude, GPT, Gemini 等多种模型
# 获取 API Key: https://openrouter.ai/keys
AI_OPENROUTER_API_KEY=your-openrouter-api-key
AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.6
AI_OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4.6
# 可选：设置 Referer 和 Title（用于 OpenRouter 统计）
AI_OPENROUTER_REFERER=https://your-site.com
AI_OPENROUTER_TITLE=Your App Name
AI_OPENROUTER_ENABLED=false

# MiniMax 配置
# MiniMax 是中国 AI 公司，提供 minimax-text-01 等大语言模型
# 获取 API Key: https://www.minimaxi.com/
AI_MINIMAX_API_KEY=your-minimax-api-key
AI_MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
AI_MINIMAX_DEFAULT_MODEL=minimax-text-01
AI_MINIMAX_CHAT_MODEL=minimax-text-01
AI_MINIMAX_ENABLED=false

# 智谱 AI (Zhipu AI / GLM) 配置
# 智谱 AI 是中国的大模型公司，提供 GLM-4、GLM-3 等系列模型
# 获取 API Key: https://open.bigmodel.cn/
AI_ZHIPU_API_KEY=your-zhipu-api-key
AI_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_ZHIPU_DEFAULT_MODEL=glm-4
AI_ZHIPU_CHAT_MODEL=glm-4
AI_ZHIPU_EMBEDDING_MODEL=embedding-3
AI_ZHIPU_ENABLED=false
